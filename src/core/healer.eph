// =============================================================================
// session-sentinel :: src/core/healer.eph
// =============================================================================
// Self-healing engine for AI session storage.
//
// Rewritten from AffineScript to Ephapax. Key change: deletion handles
// are linear (let!) — every rm/rmdir operation must be explicitly
// completed or error-handled. No silent drops means no partial deletes.
//
// Safety invariants (carried forward from AffineScript):
//   - NEVER delete data belonging to a running AI session.
//   - NEVER delete model files unless the provider config allows auto_heal.
//   - Every action is logged before execution.
//   - Dry-run mode is supported.
//
// Status: WIP — Ephapax rewrite in progress.
// =============================================================================

use std::io;

// ---------------------------------------------------------------------------
// Heal actions — integer tags for FFI compatibility
// ---------------------------------------------------------------------------

fn action_prune_orphans(): i32 = 0
fn action_prune_stale_conversations(): i32 = 1
fn action_prune_stale_subagents(): i32 = 2
fn action_remove_empty_dirs(): i32 = 3
fn action_prune_worktrees(): i32 = 4

/// Human-readable description of a heal action.
fn describe_action(action: i32): String@r = {
    region r {
        if action == 0 then String.new@r("Prune orphaned subagent directories")
        else if action == 1 then String.new@r("Prune stale conversations")
        else if action == 2 then String.new@r("Prune stale subagent dirs")
        else if action == 3 then String.new@r("Remove empty directories")
        else String.new@r("Prune orphaned git worktrees")
    }
}

// ---------------------------------------------------------------------------
// Heal result
// ---------------------------------------------------------------------------

/// Outcome of a healing run.
pub struct HealResult {
    bytes_freed: i64,
    actions_taken_count: i32,
    error_count: i32,
    fully_successful: bool,
    duration_ms: i64
}

/// Construct an empty (no-op) heal result.
fn empty_result(): HealResult = {
    HealResult {
        bytes_freed: 0,
        actions_taken_count: 0,
        error_count: 0,
        fully_successful: true,
        duration_ms: 0
    }
}

