// ---------------------------------------------------------------------------
// Action plan generation
// ---------------------------------------------------------------------------

/// Determine which actions to take based on the current health zone.
///
/// Aggressiveness increases with zone severity:
///   Green  -> no action
///   Yellow -> PruneOrphans, RemoveEmptyDirs
///   Red    -> Yellow + PruneStaleSubagents, PruneStaleConversations, PruneWorktrees
///   Purple -> Red but with max_age = 1 day (aggressive)
///
/// Returns a bitmask of actions to take.
fn plan_actions(zone: i32): i32 = {
    if zone == 0 then 0     // Green: no action
    else if zone == 1 then  // Yellow: orphans + empty dirs
        (1 + 8)             // bits 0 and 3
    else if zone == 2 then  // Red: all actions
        (1 + 2 + 4 + 8 + 16)
    else                    // Purple: all actions (aggressive thresholds)
        (1 + 2 + 4 + 8 + 16)
}

// ---------------------------------------------------------------------------
// Public API
// ---------------------------------------------------------------------------

/// Execute the self-healing engine for all configured providers.
///
/// KEY EPHAPAX DESIGN: The entire heal cycle is structured as a
/// sequence of linear resource acquisitions and releases. Each
/// provider's healing is a self-contained scope where all file
/// handles are opened, used, and closed within the scope boundary.
///
/// The AffineScript version's crash-inducing pattern was:
///   1. Open dir handle (affine)
///   2. Exception during scan
///   3. Handle implicitly dropped (GC-dependent timing)
///   4. D-Bus poll blocked on I/O
///   5. Watchdog kills process (SIGABRT)
///
/// The Ephapax version prevents this because:
///   1. Open dir handle (linear, let!)
///   2. Exception during scan
///   3. COMPILE ERROR: linear handle not consumed
///   → Forces developer to add explicit error-path cleanup
fn auto_heal(
    zone: i32,
    enable_self_healing: bool,
    providers_count: i32,
    dry_run: bool,
    now: i64
): HealResult = {
    // Short-circuit if healing is disabled or zone is healthy.
    if !enable_self_healing then empty_result()
    else if zone == 0 then empty_result()
    else {
        let mut total_freed: i64 = 0;
        let mut action_count: i32 = 0;
        let mut error_count: i32 = 0;

        let actions_mask = plan_actions(zone) in

        // TODO: iterate providers, check auto_heal and active sessions,
        // execute planned actions with linear handles

        let end = now in  // TODO: actual clock
        HealResult {
            bytes_freed: total_freed,
            actions_taken_count: action_count,
            error_count: error_count,
            fully_successful: error_count == 0,
            duration_ms: 0
        }
    }
}
