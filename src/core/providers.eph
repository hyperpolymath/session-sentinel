// =============================================================================
// session-sentinel :: src/core/providers.eph
// =============================================================================
// AI provider detection and registration.
//
// Rewritten from AffineScript to Ephapax. Provider detection probes
// the filesystem with linear directory handles — each probe is
// a self-contained scope that opens, checks, and closes.
//
// Status: WIP — Ephapax rewrite in progress.
// =============================================================================

use std::io;

// ---------------------------------------------------------------------------
// Provider type tags
// ---------------------------------------------------------------------------

/// Determines how storage is scanned for a given AI tool.
fn provider_claude(): i32 = 0    // JSONL conversations, subagent dirs
fn provider_ollama(): i32 = 1    // Large model blobs
fn provider_generic(): i32 = 2   // Flat directory size scan
fn provider_custom(): i32 = 3    // User-defined

// ---------------------------------------------------------------------------
// Provider template
// ---------------------------------------------------------------------------

/// Describes a known AI provider's storage layout.
pub struct ProviderTemplate {
    name: String@r,
    provider_type: i32,
    detection_path: String@r,
    storage_path: String@r,
    default_stale_days: i32,
    default_scan_interval: i32,  // -1 means None
    default_auto_heal: bool,
    weight: i32,                 // x100 (100 = 1.0, 10 = 0.1)
    description: String@r
}

// ---------------------------------------------------------------------------
// Built-in provider templates
// ---------------------------------------------------------------------------

/// Claude Code — primary target of session-sentinel.
fn claude_template(): ProviderTemplate = {
    region r {
        ProviderTemplate {
            name: String.new@r("Claude"),
            provider_type: provider_claude(),
            detection_path: String.new@r(".claude/"),
            storage_path: String.new@r(".claude/"),
            default_stale_days: 7,
            default_scan_interval: -1,
            default_auto_heal: true,
            weight: 100,
            description: String.new@r("Claude Code conversations, subagent dirs, session metadata")
        }
    }
}

