// ---------------------------------------------------------------------------
// Detection
// ---------------------------------------------------------------------------

/// Check whether a provider template matches the current filesystem.
///
/// KEY EPHAPAX CHANGE: Directory probe uses linear handle.
/// Open, check existence, close — all in one scope. The old
/// AffineScript version could leave stat handles open across
/// the entire provider detection loop.
fn is_provider_present(home: &String@r, template: &ProviderTemplate): bool = {
    region r {
        let full_path = String.concat@r(home, &template.detection_path) in
        // Linear probe handle
        let! probe = io::Dir.try_open(&full_path) in
        let exists = io::Dir.is_valid(&probe) in
        drop(probe);  // Explicit close — cannot leak
        drop(full_path);
        exists
    }
}

/// Auto-detect which AI tools are installed.
///
/// Returns count of detected providers. Detected configs are written
/// into the output array.
fn detect_providers(home: &String@r): i32 = {
    let mut detected: i32 = 0;

    // Check each template with linear probes
    let t_claude = claude_template() in
    if is_provider_present(home, &t_claude) then
        detected = detected + 1
    else ();

    let t_copilot = copilot_template() in
    if is_provider_present(home, &t_copilot) then
        detected = detected + 1
    else ();

    let t_ollama = ollama_template() in
    if is_provider_present(home, &t_ollama) then
        detected = detected + 1
    else ();

    let t_lmstudio = lmstudio_template() in
    if is_provider_present(home, &t_lmstudio) then
        detected = detected + 1
    else ();

    let t_continue = continue_template() in
    if is_provider_present(home, &t_continue) then
        detected = detected + 1
    else ();

    let t_cursor = cursor_template() in
    if is_provider_present(home, &t_cursor) then
        detected = detected + 1
    else ();

    let t_aider = aider_template() in
    if is_provider_present(home, &t_aider) then
        detected = detected + 1
    else ();

    detected
}

// ---------------------------------------------------------------------------
// Process detection
// ---------------------------------------------------------------------------

/// Map provider names to process names for active session detection.
fn process_pattern_for(provider_type: i32): String@r = {
    region r {
        if provider_type == 0 then String.new@r("claude")
        else if provider_type == 1 then String.new@r("ollama")
        else String.new@r("")
    }
}

/// Check if detailed scanning is supported for this provider type.
fn supports_detailed_scan(provider_type: i32): bool = {
    provider_type == provider_claude()
}
