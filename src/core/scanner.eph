fn aggregate_bytes(snapshots: &[ProviderSnapshot], count: i32): i64 = {
    let mut total: i64 = 0;
    // TODO: sum snapshot.total_bytes
    total
}

/// Convenience: compute the aggregate orphan count across all snapshots.
fn aggregate_orphans(snapshots: &[ProviderSnapshot], count: i32): i32 = {
    let mut total: i32 = 0;
    // TODO: sum snapshot.orphan_count
    total
}
